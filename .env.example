# Frontend (Vercel)
NEXT_PUBLIC_API_BASE_URL=https://api.whatistaspp.com
API_PROXY_TARGET=https://api.whatistaspp.com

# Backend (Hetzner)
PUBLIC_API_BASE_URL=https://api.whatistaspp.com
CORS_ALLOWED_ORIGINS=https://whatistaspp.com,https://whatistaspp.vercel.app
JWT_SECRET=change-this-to-a-long-random-secret

# Optional integrations
GEMINI_API_KEY=

# Local/stateful backend paths stay on Hetzner
# SQLite default: data/database.db
# WhatsApp sessions default: data/auth_info
# Uploads default: data/uploads
